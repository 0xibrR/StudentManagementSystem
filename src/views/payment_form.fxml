<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.PaymentController">

    <top>
        <Label text="Student Payment"
               BorderPane.alignment="CENTER"
               style="-fx-font-size:22px;
                      -fx-font-weight:bold;
                      -fx-padding:15;" />
    </top>

    <center>

        <GridPane alignment="CENTER"
                  hgap="15"
                  vgap="15">

            <padding>
                <Insets top="20"
                        right="20"
                        bottom="20"
                        left="20"/>
            </padding>

            <!-- Student -->
            <Label text="Student"/>

            <Label fx:id="lblStudent"
                   GridPane.columnIndex="1"/>

            <!-- Payment Method -->
            <Label text="Payment Method"
                   GridPane.rowIndex="1"/>

            <ComboBox fx:id="cmbMethod"
                      prefWidth="200"
                      GridPane.columnIndex="1"
                      GridPane.rowIndex="1"/>

            <!-- Cash -->
            <Label text="Cash Amount"
                   GridPane.rowIndex="2"/>

            <TextField fx:id="txtCash"
                       GridPane.columnIndex="1"
                       GridPane.rowIndex="2"/>

            <!-- Bank -->
            <Label text="Bank Amount"
                   GridPane.rowIndex="3"/>

            <TextField fx:id="txtBank"
                       GridPane.columnIndex="1"
                       GridPane.rowIndex="3"/>

            <!-- Amount Due -->
            <Label text="Amount Due"
                   GridPane.rowIndex="4"/>

            <TextField fx:id="txtAmountDue"
                       GridPane.columnIndex="1"
                       GridPane.rowIndex="4"/>

            <!-- Paid -->
            <Label text="Paid"
                   GridPane.rowIndex="5"/>

            <TextField fx:id="txtPaid"
                       editable="false"
                       GridPane.columnIndex="1"
                       GridPane.rowIndex="5"/>

            <!-- Remaining -->
            <Label text="Remaining"
                   GridPane.rowIndex="6"/>

            <TextField fx:id="txtRemaining"
                       editable="false"
                       GridPane.columnIndex="1"
                       GridPane.rowIndex="6"/>

            <!-- Notes -->
            <Label text="Notes"
                   GridPane.rowIndex="7"/>

            <TextArea fx:id="txtNotes"
                      prefRowCount="4"
                      GridPane.columnIndex="1"
                      GridPane.rowIndex="7"/>

        </GridPane>

    </center>

    <bottom>

        <HBox alignment="CENTER"
              spacing="15"
              style="-fx-padding:15;">

            <Button text="Save Payment"
                    onAction="#handleSave"/>

            <Button text="Cancel"
                    onAction="#handleCancel"/>

        </HBox>

    </bottom>

</BorderPane>